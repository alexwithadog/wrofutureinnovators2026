import os
import sounddevice as sd
import lameenc
from openai import OpenAI
from google import genai
from dotenv import load_dotenv

# 🔑 Load keys
load_dotenv()
open_ai_client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))
google_client = genai.Client(api_key=os.getenv("GEMINI_API_KEY"))

# 🎤 RECORD AUDIO
def record_to_mp3(filename="input.mp3", duration=3, samplerate=44100):
    audio = sd.rec(int(duration * samplerate), samplerate=samplerate, channels=1, dtype='int16')
    sd.wait()

    encoder = lameenc.Encoder()
    encoder.set_bit_rate(128)
    encoder.set_in_sample_rate(samplerate)
    encoder.set_channels(1)
    encoder.set_quality(2)

    mp3_data = encoder.encode(audio.tobytes())
    mp3_data += encoder.flush()

    with open(filename, "wb") as f:
        f.write(mp3_data)

# 🧠 SPEECH → TEXT
def speech_to_text(file="input.mp3"):
    try:
        with open(file, "rb") as f:
            result = open_ai_client.audio.transcriptions.create(
                model="gpt-4o-transcribe",
                file=f
            )
        return result.text.lower()
    except Exception as e:
        print("STT error:", e)
        return ""

# 🤖 AI RESPONSE
def ask_ai(text):
    try:
        prompt = f"""
You are a friendly museum guide robot.

User said: "{text}"

Rules:
- Respond in same language
- Keep answer short (1 sentence)
- Be clear and educational
"""
        response = google_client.models.generate_content(
            model="gemini-3-flash-preview",
            contents=prompt
        )
        return response.text
    except Exception as e:
        print("AI error:", e)
        return "Sorry, I couldn't answer that."

# 🔊 TEXT → SPEECH
def speak(text):
    try:
        speech = open_ai_client.audio.speech.create(
            model="gpt-4o-mini-tts",
            voice="alloy",
            input=text
        )

        with open("output.mp3", "wb") as f:
            f.write(speech.read())

        os.system("mpg123 output.mp3")
    except Exception as e:
        print("TTS error:", e)

# 🚀 MAIN LOOP
def main():
    print("🤖 Robot started. Say 'hey guide'...")

    while True:
        record_to_mp3()

        text = speech_to_text()
        if not text:
            continue

        print("Heard:", text)

        # 🎯 WAKE WORD
        if "hey guide" not in text:
            continue

        speak("Hello, I am your guide.")

        command = text.replace("hey guide", "").strip()

        if not command:
            speak("How can I help you?")
            continue

        answer = ask_ai(command)
        print("Answer:", answer)

        speak(answer)

# ▶️ RUN
if __name__ == "__main__":
    main()
