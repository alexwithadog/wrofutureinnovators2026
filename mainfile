import os
import time
import pyttsx3
from dotenv import load_dotenv
from google import genai

# =========================
# 🔐 LOAD ENV
# =========================
load_dotenv()

GEMINI_API_KEY = os.getenv("GEMINI_API_KEY")

if not GEMINI_API_KEY:
    print("❌ Gemini API key not found. Check your .env file.")
    exit()

# =========================
# 🤖 GEMINI SETUP
# =========================
client = genai.Client(api_key=GEMINI_API_KEY)

# =========================
# 🔊 TEXT TO SPEECH
# =========================
engine = pyttsx3.init(driverName='espeak')
engine.setProperty('rate', 170)

def speak(text):
    print(f"🤖: {text}")
    engine.say(text)
    engine.runAndWait()

# =========================
# 🎤 SETTINGS
# =========================
USE_MIC = False   # 🔥 CHANGE TO True when mic works

# =========================
# 🎤 MIC FUNCTION (basic placeholder)
# =========================
def listen():
    # You will replace this later with real mic code
    return input("🎤 You: ")

# =========================
# 🧠 ASK GEMINI
# =========================
def ask_gemini(prompt):
    try:
        response = client.models.generate_content(
            model="gemini-1.5-flash",
            contents=prompt
        )
        return response.text
    except Exception as e:
        return f"⚠️ Error: {e}"

# =========================
# 🤖 MAIN LOOP
# =========================
def main():
    speak("Hello! I am your cultural guide. Say 'hey guide' to begin.")

    while True:
        if USE_MIC:
            text = listen()
        else:
            text = input("⌨️ Type: ")

        text = text.lower()

        # Exit
        if "exit" in text or "quit" in text:
            speak("Goodbye!")
            break

        # Wake word
        if "hey guide" in text:
            speak("Yes, how can I help you?")

            if USE_MIC:
                user_question = listen()
            else:
                user_question = input("⌨️ Question: ")

            speak("Let me think...")

            answer = ask_gemini(user_question)

            speak(answer)

        else:
            print("💤 Waiting for 'hey guide'...")

# =========================
# ▶️ RUN
# =========================
if __name__ == "__main__":
    main()