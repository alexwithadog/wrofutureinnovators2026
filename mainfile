import os
import sounddevice as sd
import soundfile as sf
from dotenv import load_dotenv
import pyttsx3
from openai import OpenAI
from google import genai

# 🔑 LOAD KEYS
load_dotenv()

openai_client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))
gemini_client = genai.Client(api_key=os.getenv("GEMINI_API_KEY"))

# 🔊 TTS (offline)
engine = pyttsx3.init()

def speak(text):
    print("🔊:", text)
    engine.say(text)
    engine.runAndWait()

# 🎤 RECORD AUDIO
def record_audio(filename="input.wav", duration=3):
    fs = 16000
    print("\n🎤 Listening...")
    
    audio = sd.rec(int(duration * fs), samplerate=fs, channels=1)
    sd.wait()

    sf.write(filename, audio, fs)
    print("✅ Recorded")

# 🧠 STT (Whisper → fallback Gemini)
def speech_to_text(filename="input.wav"):
    try:
        with open(filename, "rb") as f:
            result = openai_client.audio.transcriptions.create(
                model="gpt-4o-transcribe",
                file=f
            )
        print("✅ Using Whisper")
        return result.text.lower()
    except Exception as e:
        print("⚠️ Whisper failed:", e)

    try:
        with open(filename, "rb") as f:
            audio_bytes = f.read()

        response = gemini_client.models.generate_content(
            model="gemini-2.0-flash",
            contents=[
                {"role": "user", "parts": [
                    {"text": "Transcribe this audio."},
                    {"inline_data": {"mime_type": "audio/wav", "data": audio_bytes}}
                ]}
            ]
        )

        print("✅ Using Gemini STT")
        return response.text.lower()
    except Exception as e:
        print("❌ STT failed:", e)
        return ""

# 🤖 AI RESPONSE
def ask_ai(text):
    prompt = f"""
You are a cultural museum guide robot.

User said: "{text}"

Rules:
- Respond in same language
- Keep it SHORT (1 sentence)
- Be clear and educational
"""
    response = gemini_client.models.generate_content(
        model="gemini-2.0-flash",
        contents=prompt
    )
    return response.text

# 🚀 MAIN LOOP
def main():
    print("🤖 Robot ready. Say 'hey guide'...")

    while True:
        record_audio()

        text = speech_to_text()
        if not text:
            continue

        print("👂 Heard:", text)

        if "hey guide" not in text:
            continue

        speak("Hello, I am your guide.")

        command = text.replace("hey guide", "").strip()

        if not command:
            speak("How can I help you?")
            continue

        answer = ask_ai(command)
        print("🤖 Answer:", answer)

        speak(answer)

if __name__ == "__main__":
    main()
